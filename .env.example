# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- WhatsApp Cloud API (GrowthMonk's owned WhatsApp business number) ---
# Token used to verify incoming Meta webhook subscription requests.
VERIFY_TOKEN=replace_with_a_long_random_string

# Permanent or long-lived system user token for GrowthMonk's own WhatsApp Cloud API.
WHATSAPP_TOKEN=replace_with_whatsapp_cloud_api_token

# Phone number ID of GrowthMonk's owned WhatsApp business number.
PHONE_NUMBER_ID=replace_with_phone_number_id

# WhatsApp Business Account ID for GrowthMonk's owned account.
WABA_ID=replace_with_waba_id

# Optional: Meta App Secret, used to verify X-Hub-Signature-256 on incoming webhooks.
META_APP_SECRET=

# --- Internal API ---
# Required on the /send-test endpoint via the x-api-key header.
INTERNAL_API_KEY=replace_with_a_long_random_string

# --- Optional Bot Integration ---
# If set, inbound messages are forwarded to this URL and its reply is sent back to the customer.
BOT_API_URL=

# --- Optional Telegram Alerts ---
# Used to alert the GrowthMonk team on hot leads and human-handoff requests.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
